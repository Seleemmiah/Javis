# J.A.R.V.I.S. Environment Config
# Rename this file to .env and fill in your values.

# 1. API Keys (Mandatory for Cloud Brain, Free for Ollama)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-api-key-here"

# Get a key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=""

# 2. Local Brain (100% Free)
# Set JARVIS_USE_OLLAMA="always" if you don't want to use OpenAI at all.
JARVIS_USE_OLLAMA="auto"
OLLAMA_MODEL="llama3.2"

# 3. Voice Settings
# System voice options: Shelley, Flo, Daniel (macOS default is Shelley)
JARVIS_VOICE="Shelley"
# Set to 'system' to use offline macOS voice, or 'edge' to use Neural voice
JARVIS_TTS="edge"
